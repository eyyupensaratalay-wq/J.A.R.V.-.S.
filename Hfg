<!DOCTYPE html>
<html lang="tr">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>J.A.R.V.I.S.</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    background-color: #010c14;
    color: #e0f2fe;
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    display: flex;
    flex-direction: column;
    height: 100vh;
    overflow: hidden;
  }
  header {
    background: linear-gradient(180deg, #021526 0%, #010c14 100%);
    padding: 15px;
    text-align: center;
    border-bottom: 2px solid #00e6ff;
    box-shadow: 0 0 15px rgba(0, 230, 255, 0.3);
  }
  header h1 {
    color: #00e6ff;
    font-size: 22px;
    letter-spacing: 2px;
    text-shadow: 0 0 8px rgba(0, 230, 255, 0.6);
  }
  #chat-container {
    flex: 1;
    padding: 20px;
    overflow-y: auto;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .message {
    max-width: 80%;
    padding: 12px 16px;
    border-radius: 12px;
    line-height: 1.5;
    font-size: 15px;
    animation: fadeIn 0.3s ease;
  }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(5deg); } to { opacity: 1; transform: translateY(0); } }
  .user {
    background-color: #0c4a6e;
    color: #f0f9ff;
    align-self: flex-end;
    border-bottom-right-radius: 2px;
    border: 1px solid #0284c7;
  }
  .assistant {
    background-color: #0f172a;
    color: #e2e8f0;
    align-self: flex-start;
    border-bottom-left-radius: 2px;
    border: 1px solid #334155;
    box-shadow: 0 0 10px rgba(0, 230, 255, 0.1);
  }
  #input-container {
    padding: 15px;
    background-color: #021526;
    display: flex;
    gap: 10px;
    border-top: 1px solid rgba(0, 230, 255, 0.2);
  }
  input[type="text"] {
    flex: 1;
    background-color: #010c14;
    border: 1px solid #00e6ff;
    border-radius: 8px;
    color: #fff;
    padding: 12px;
    font-size: 15px;
    outline: none;
  }
  input[type="text"]:focus {
    box-shadow: 0 0 8px rgba(0, 230, 255, 0.5);
  }
  button {
    background-color: #00e6ff;
    color: #010c14;
    border: none;
    border-radius: 8px;
    padding: 0 20px;
    font-weight: bold;
    cursor: pointer;
    transition: all 0.2s;
  }
  button:hover {
    background-color: #00b8cc;
    box-shadow: 0 0 10px rgba(0, 230, 255, 0.5);
  }
  #status-bar {
    font-size: 12px;
    color: #00e6ff;
    text-align: center;
    padding: 5px;
    background-color: #010c14;
    opacity: 0.8;
  }
</style>
</head>
<body>

<header>
  <h1>J.A.R.V.I.S. SİSTEMİ</h1>
</header>

<div id="chat-container">
  <div class="message assistant">Sistem çevrimiçi, Efendim. Sizi dinliyorum.</div>
</div>

<div id="status-bar" id="status">Durum: Hazır</div>

<div id="input-container">
  <input type="text" id="user-input" placeholder="Jarvis'e bir emir verin..." onkeypress="if(event.key==='Enter') sendMessage()"/>
  <button onclick="sendMessage()">Gönder</button>
</div>

<script>
  // Senin verdiğin çalışan API anahtarın doğrudan buraya eklendi
  const apiKey = "AIzaSyATaN__sWnjKVDpGH9APovFM8N7D1HJtfs";
  
  // Gemini API'nin güncellenmiş yeni veri formatı yapısı
  const apiUrl = `https://generativelanguage.googleapis.com/v1beta/models/gemini-1.5-flash:generateContent?key=${apiKey}`;

  let chatHistory = [
    { role: "user", parts: [{ text: "Sen Tony Stark'ın yapay zekası Jarvis'sin. Bana her zaman kibar bir şekilde 'Efendim' diye hitap edeceksin." }] },
    { role: "model", parts: [{ text: "Anlaşıldı Efendim. J.A.R.V.I.S. emirlerinize amadedir." }] }
  ];

  const chatContainer = document.getElementById('chat-container');
  const statusBar = document.getElementById('status-bar');

  function addMessage(sender, text) {
    const msg = document.createElement('div');
    msg.classList.add('message', sender);
    msg.innerHTML = text;
    chatContainer.appendChild(msg);
    chatContainer.scrollTop = chatContainer.scrollHeight;
  }

  async function sendMessage() {
    const inputEl = document.getElementById('user-input');
    const text = inputEl.value.trim();
    if (!text) return;

    addMessage('user', text);
    inputEl.value = '';
    statusBar.innerText = "Durum: Jarvis düşünüyor...";

    // Kullanıcı mesajını geçmişe ekle (Doğru 'parts' yapısı ile)
    chatHistory.push({ role: "user", parts: [{ text: text }] });

    // Eğer istek resim üretme üzerineyse resim motoruna yönlendir
    if (text.toLowerCase().includes("resim çiz") || text.toLowerCase().includes("görsel üret") || text.toLowerCase().includes("fotoğraf oluştur")) {
      await generateImage(text);
      return;
    }

    try {
      const response = await fetch(apiUrl, {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ contents: chatHistory })
      });

      const data = await response.json();
      
      // Gelen veriyi güvenle oku (parts hatasını önleyen kontrol)
      if (data.candidates && data.candidates[0].content && data.candidates[0].content.parts) {
        const replyText = data.candidates[0].content.parts[0].text;
        addMessage('assistant', replyText);
        chatHistory.push({ role: "model", parts: [{ text: replyText }] });
      } else {
        addMessage('assistant', "Bağlantıda bir sorun oluştu Efendim. API anahtarınızı veya limitinizi kontrol etmek isteyebilirsiniz.");
        console.error("API Hatası:", data);
      }
    } catch (error) {
      addMessage('assistant', "Sistem hatası alındı Efendim. Arka plan bağlantısı başarısız.");
      console.error(error);
    } finally {
      statusBar.innerText = "Durum: Hazır";
    }
  }

  // Pollinations AI - Yeni Güncel Ücretsiz Flux Model Motoru
  async function generateImage(promptText) {
    statusBar.innerText = "Durum: Görsel render ediliyor...";
    try {
      const cleanPrompt = encodeURIComponent(promptText.replace(/(resim çiz|görsel üret|fotoğraf oluştur)/gi, ""));
      const seed = Math.floor(Math.random() * 99999);
      // flux-pro yerine tamamen stabil çalışan ücretsiz 'flux' modeline güncellendi
      const imageUrl = `https://image.pollinations.ai/prompt/${cleanPrompt}?width=768&height=768&seed=${seed}&nologo=true&model=flux`;

      const reply = `İstediğiniz görseli hazırladım Efendim. Arka planda render tamamlandı.`;
      const imgHtml = `<div>${reply}<br><img src="${imageUrl}" style="max-width:100%; border-radius:8px; margin-top:10px; border:1px solid #00e6ff; box-shadow: 0 0 8px rgba(0,230,255,0.3);"/></div>`;
      
      addMessage('assistant', imgHtml);
      chatHistory.push({ role: "model", parts: [{ text: reply }] });
    } catch (e) {
      addMessage('assistant', "Görsel motoru şu an yanıt vermiyor Efendim.");
    } finally {
      statusBar.innerText = "Durum: Hazır";
    }
  }
</script>

</body>
</html>
